# MiniMax M2.7 (Anthropic format) — default config
ANTHROPIC_API_KEY=your_minimax_token_plan_key_here
# MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic  # default, can omit

# MiniMax M2.5 (OpenAI format) — set CODER_API_FORMAT=openai to switch back
# LLM_API_KEY=your_LLM_api_key_here
# LLM_BASE_URL=your_LLM_api_base_url_here

# Optional overrides
# CODER_MODEL=MiniMax-M2.7
# CODER_API_FORMAT=anthropic
# CODER_MAX_TOKENS=8192
# CODER_MAX_STEPS=20
# CODER_WORKSPACE=./workspace
# CODER_VERBOSE=false
