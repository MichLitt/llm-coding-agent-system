# ── Profile: minimax_m27 (default, Anthropic transport) ──────────────────────
LLM_MINIMAX_M27_API_KEY=your_minimax_token_plan_key_here
# LLM_MINIMAX_M27_BASE_URL=https://api.minimax.io/anthropic  # default, can omit

# ── Profile: minimax_m25 (OpenAI transport) ──────────────────────────────────
# LLM_MINIMAX_M25_API_KEY=your_minimax_m25_key
# LLM_MINIMAX_M25_BASE_URL=https://api.minimax.io/v1

# ── Profile: glm_5 (OpenAI-compatible transport) ─────────────────────────────
# LLM_GLM_5_API_KEY=your_glm_api_key
# LLM_GLM_5_BASE_URL=https://api.z.ai/api/coding/paas/v4  # default, can omit

# ── Optional runtime overrides (prefer --llm-profile over these) ─────────────
# CODER_MAX_TOKENS=8192
# CODER_MAX_STEPS=20
# CODER_WORKSPACE=./workspace
# CODER_VERBOSE=false
